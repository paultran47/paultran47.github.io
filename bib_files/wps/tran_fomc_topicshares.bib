@unpublished{tran_fomc_topicshares,
  author = {Paul L. Tran},
  year = {2026},
  title = {Does the Topic Mix of Monetary Policy Announcements Affect Market Expectations?},
  opturl = {https://paulletran.com/papers/wps/tran_paul_le_fomc_nn_paper_jmp.pdf},
  note = {Draft soon},
  abstract = {\textit{Abstract}: This paper finds that the thematic composition of FOMC post-meeting statements affects market expectations of future monetary policy. I quantify changes in the communication bandwidth dedicated to specific topics using large-language-model probabilistic topic classification. Through an event study approach, I find that an increase in the intensity of discussion regarding monetary policy tools (economic conditions) is associated with an increase (decrease) in the variation of monetary policy surprises calculated with high-frequency federal funds futures prices. These results suggest that thematic content conveys information to the market distinct from the structural, semantic change of the announcement.}
}